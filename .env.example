# Message broker (RabbitMQ)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Topology (must match services/broker after setup)
FRAMES_EXCHANGE=pizza.frames
RESULTS_EXCHANGE=pizza.results
FRAMES_QUEUE=q.frames.detection
RESULTS_QUEUE=q.results.streaming
DLX_EXCHANGE=pizza.dlx
FRAMES_DLQ=q.frames.detection.dlq
RESULTS_DLQ=q.results.streaming.dlq

# Default camera id for routing keys (camera.<id>.frame / camera.<id>.result)
CAMERA_ID=default

# Frame reader
VIDEO_SOURCE=0
# or file path: /data/videos/sample.mp4
# or RTSP: rtsp://user:pass@camera/stream
JPEG_QUALITY=80
FRAME_READER_FPS=0

# Detection
MODEL_PATH=/models/yolo12m.pt

# Streaming API
STREAMING_HOST=0.0.0.0
STREAMING_PORT=8000

# Database (violations)
DATABASE_URL=postgresql+asyncpg://pizza:pizza@postgres:5432/violations
